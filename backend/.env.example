# Backend environment variables
# Copy this file to backend/.env and fill in your values
# NEVER commit .env to version control

PORT=5000
MONGODB_URI=mongodb://localhost:27017/portfolio
JWT_SECRET=your_jwt_secret_here_change_in_production_min_32_chars
CLIENT_ORIGIN=http://localhost:5173

# Admin credentials for /api/auth/login
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

NODE_ENV=development
